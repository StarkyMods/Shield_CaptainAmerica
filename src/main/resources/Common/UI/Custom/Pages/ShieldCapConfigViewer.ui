$Common = "../Common.ui";

@TitleStyle = LabelStyle(FontSize: 26, TextColor: #ffe6e6, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
@TabLabelStyle = LabelStyle(FontSize: 15, TextColor: #ffcfcf, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
@TabButtonStyle = TextButtonStyle(Default: (Background: #341515, LabelStyle: @TabLabelStyle), Hovered: (Background: #421d1d, LabelStyle: @TabLabelStyle), Pressed: (Background: #522323, LabelStyle: @TabLabelStyle), Disabled: (Background: #341515(0.6), LabelStyle: @TabLabelStyle));
@ApplyLabelStyle = LabelStyle(FontSize: 14, TextColor: #ffe6e6, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
@ApplyButtonStyle = TextButtonStyle(Default: (Background: #5a1e1e, LabelStyle: @ApplyLabelStyle), Hovered: (Background: #772828, LabelStyle: @ApplyLabelStyle), Pressed: (Background: #481a1a, LabelStyle: @ApplyLabelStyle), Disabled: (Background: #5a1e1e(0.6), LabelStyle: @ApplyLabelStyle));
@SectionLabelStyle = LabelStyle(FontSize: 19, TextColor: #d39f9f, RenderBold: true, LetterSpacing: 1, RenderUppercase: true);
@BodyTextStyle = LabelStyle(FontSize: 15, TextColor: #a87f7f, Wrap: true);
@CenteredBodyTextStyle = LabelStyle(FontSize: 15, TextColor: #cfa7a7, Wrap: true, HorizontalAlignment: Center);
@HomeLargeTitleStyle = LabelStyle(FontSize: 22, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
@HomeCardHeaderStyle = LabelStyle(FontSize: 10, TextColor: #f9e6e6, RenderBold: true, LetterSpacing: 1, HorizontalAlignment: Center);
@HomeCardTitleStyle = LabelStyle(FontSize: 18, TextColor: #ffffff, RenderBold: true, Wrap: true, HorizontalAlignment: Center, VerticalAlignment: Center);
@HomeCardTagStyle = LabelStyle(FontSize: 11, TextColor: #ff8989, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
@HomeCardBodyStyle = LabelStyle(FontSize: 12, TextColor: #e8bdbd, Wrap: true, HorizontalAlignment: Center);
@RowLabelStyle = LabelStyle(FontSize: 14, TextColor: #ddb3b3, VerticalAlignment: Center);
@NoteTextStyle = LabelStyle(FontSize: 14, TextColor: #a37b7b, Wrap: true);
@VersionTextStyle = LabelStyle(FontSize: 13, TextColor: #d8b0b0, RenderBold: true, VerticalAlignment: Center);
@NumberFieldStyle = (FontSize: 14, TextColor: #ffe6e6);
@NumberFieldPlaceholderStyle = (FontSize: 14, TextColor: #956b6b);
@TextFieldStyle = @NumberFieldStyle;
@TextFieldPlaceholderStyle = @NumberFieldPlaceholderStyle;
@ViewerFieldTextStyle = LabelStyle(FontSize: 14, TextColor: #ffe6e6, VerticalAlignment: Center);
@ViewerValueTextStyle = LabelStyle(FontSize: 14, TextColor: #ffe6e6, VerticalAlignment: Center);
@RemoveLabelStyle = LabelStyle(FontSize: 14, TextColor: #f2dada, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
@RemoveButtonStyle = TextButtonStyle(Default: (Background: #3a1c1c, LabelStyle: @RemoveLabelStyle), Hovered: (Background: #4a2323, LabelStyle: @RemoveLabelStyle), Pressed: (Background: #2a1414, LabelStyle: @RemoveLabelStyle), Disabled: (Background: #3a1c1c(0.6), LabelStyle: @RemoveLabelStyle));
@AddButtonStyle = TextButtonStyle(Default: (Background: #3d1e1e, LabelStyle: @ApplyLabelStyle), Hovered: (Background: #4b2424, LabelStyle: @ApplyLabelStyle), Pressed: (Background: #371818, LabelStyle: @ApplyLabelStyle), Disabled: (Background: #3d1e1e(0.6), LabelStyle: @ApplyLabelStyle));
@ControlBindingLabelStyle = LabelStyle(FontSize: 14, TextColor: #ffe6e6, HorizontalAlignment: Center, VerticalAlignment: Center);
@ControlBindingButtonStyle = TextButtonStyle(Default: (Background: #200d0d, LabelStyle: @ControlBindingLabelStyle), Hovered: (Background: #2d1414, LabelStyle: @ControlBindingLabelStyle), Pressed: (Background: #180909, LabelStyle: @ControlBindingLabelStyle), Disabled: (Background: #200d0d(0.6), LabelStyle: @ControlBindingLabelStyle));
@HomeTabButtonStyle = ButtonStyle(Default: (Background: "../Home_Icon.png"), Hovered: (Background: "../Home_Icon_OnTop.png"), Pressed: (Background: "../Home_Icon_OnTop.png"), Disabled: (Background: "../Home_Icon.png"));
@HomeLinkedCardButtonStyle = ButtonStyle(Default: (Background: #1f0b0b(0.92)), Hovered: (Background: #352020(0.96)), Pressed: (Background: #452626(0.98)), Disabled: (Background: #1f0b0b(0.6)));
@CompatibilityLinkedCardButtonStyle = ButtonStyle(Default: (Background: #1f0b0b(0.92)), Hovered: (Background: #382020(0.96)), Pressed: (Background: #4a2828(0.98)), Disabled: (Background: #1f0b0b(0.6)));
@MenuMiniLabelStyle = LabelStyle(FontSize: 11, TextColor: #ffe7e7, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
@MenuMiniButtonStyle = TextButtonStyle(Default: (Background: #5a1e1e, LabelStyle: @MenuMiniLabelStyle), Hovered: (Background: #733030, LabelStyle: @MenuMiniLabelStyle), Pressed: (Background: #421616, LabelStyle: @MenuMiniLabelStyle), Disabled: (Background: #5a1e1e(0.6), LabelStyle: @MenuMiniLabelStyle));
@CloseButtonLabelStyle = LabelStyle(FontSize: 12, TextColor: #ffe7e7, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
@CloseButtonStyle = TextButtonStyle(Default: (Background: #5a1e1e, LabelStyle: @CloseButtonLabelStyle), Hovered: (Background: #733030, LabelStyle: @CloseButtonLabelStyle), Pressed: (Background: #421616, LabelStyle: @CloseButtonLabelStyle), Disabled: (Background: #5a1e1e(0.6), LabelStyle: @CloseButtonLabelStyle));

Group {
    Anchor: (Width: 900, Height: 640);
    Background: #140a0a(0.94);
    LayoutMode: Top;
    Padding: (Full: 18);

    TextButton #CloseUIButton {
        Anchor: (Width: 24, Height: 24, Left: -12, Top: -12);
        Text: "X";
        Style: @CloseButtonStyle;
    }

    Group {
        LayoutMode: Left;
        Anchor: (Height: 18);

        Label #VersionLabel {
            Anchor: (Width: 90, Height: 18);
            Text: "?.?.?";
            Style: @VersionTextStyle;
        }

        Group { FlexWeight: 1; }
    }

    Group { Anchor: (Height: 0); }

    Group #HeaderRow {
        LayoutMode: Left;
        Anchor: (Height: 34);

        Group {
            Anchor: (Width: 0);
        }

        Group {
            FlexWeight: 1;
            LayoutMode: Top;
            Anchor: (Height: 34);

            Label #TitleLabel {
                Anchor: (Height: 22);
                Text: "STARKY'S CAP'S SHIELD MENU";
                Style: @TitleStyle;
            }
        }

        Group {
            LayoutMode: Top;
            Anchor: (Width: 54, Height: 34);

            Group #HeaderLogo {
                Anchor: (Width: 51, Height: 51, Top: -14);
                Background: (TexturePath: "../Starky_S_Logo_White.png");
            }
        }
    }

    Group { Anchor: (Height: 2); }

    Group #TabRow {
        LayoutMode: Left;
        Anchor: (Height: 62);

        Group #TabHome {
            LayoutMode: Top;
            Anchor: (Width: 68, Height: 62);

            Button #TabHomeButton {
                Anchor: (Width: 56, Height: 56, Left: 6);
                Style: @HomeTabButtonStyle;

                Group #TabHomeIcon {
                    Anchor: (Width: 56, Height: 56);
                    Background: #000000(0);
                }

                Group #TabHomeActive {
                    Anchor: (Width: 56, Height: 3, Top: 53);
                    Background: #ff5959;
                    Visible: false;
                }
            }
        }

        Group { Anchor: (Width: 2); }

        Group #TabMain {
            LayoutMode: Top;
            Anchor: (Height: 54);
            FlexWeight: 1;

            TextButton #TabMainButton {
                Anchor: (Height: 30, Top: 12);
                Text: "CONFIG";
                Style: @TabButtonStyle;
            }

            Group #TabMainActive {
                Anchor: (Height: 3);
                Background: #ff5959;
                Visible: false;
            }
        }

        Group { Anchor: (Width: 8); }

        Group #TabCraft {
            LayoutMode: Top;
            Anchor: (Height: 54);
            FlexWeight: 1;

            TextButton #TabCraftButton {
                Anchor: (Height: 30, Top: 12);
                Text: "CRAFTING";
                Style: @TabButtonStyle;
            }

            Group #TabCraftActive {
                Anchor: (Height: 3);
                Background: #ff5959;
                Visible: false;
            }
        }

        Group { Anchor: (Width: 8); }

        Group #TabDamage {
            LayoutMode: Top;
            Anchor: (Height: 54);
            FlexWeight: 1;

            TextButton #TabDamageButton {
                Anchor: (Height: 30, Top: 12);
                Text: "DAMAGES";
                Style: @TabButtonStyle;
            }

            Group #TabDamageActive {
                Anchor: (Height: 3);
                Background: #ff5959;
                Visible: false;
            }
        }

        Group { Anchor: (Width: 8); }

        Group #TabCompatibility {
            LayoutMode: Top;
            Anchor: (Height: 54);
            FlexWeight: 1;

            TextButton #TabCompatibilityButton {
                Anchor: (Height: 30, Top: 12);
                Text: "COMPATIBILITY";
                Style: @TabButtonStyle;
            }

            Group #TabCompatibilityActive {
                Anchor: (Height: 3);
                Background: #ff5959;
                Visible: false;
            }
        }
    }

    Group { Anchor: (Height: 10); }
    Group { Anchor: (Height: 1); Background: #472626; }
    Group { Anchor: (Height: 10); }

    Group #HomeTab {
        LayoutMode: Top;
        FlexWeight: 1;
        Visible: false;
        Padding: (Horizontal: 24);

        Group {
            LayoutMode: Middle;
            Anchor: (Height: 14);

            Group { FlexWeight: 1; }

            Group {
                LayoutMode: Left;
                Anchor: (Width: 862, Height: 20);

                Group {
                    Anchor: (Width: 76, Height: 14);
                    Label {
                        Anchor: (Width: 68, Height: 20, Left: 6, Top: -6);
                        Text: "HOME";
                        Style: @SectionLabelStyle;
                    }
                }

                Group { Anchor: (Width: 786); }
            }

            Group { FlexWeight: 1; }
        }
        
        Group #HomeScroll {
            FlexWeight: 1;
            LayoutMode: TopScrolling;
            ScrollbarStyle: $Common.@DefaultScrollbarStyle;

            Group {
                LayoutMode: Middle;
                Anchor: (Height: 300);

                Group { FlexWeight: 1; }

                Group {
                    Anchor: (Width: 529, Height: 300);
                    Background: (TexturePath: "../Starky_Shield_Wallpaper.png");
                }

                Group { FlexWeight: 1; }
            }

            Group { Anchor: (Height: 14); }

            Group {
                LayoutMode: Middle;
                Anchor: (Height: 44);

                Group { FlexWeight: 1; }

                Label {
                    Anchor: (Width: 640, Height: 44);
                    Text: "Inspired from Marvel Captain America's Shield, this is a custom weapon with lots of custom attacks, throws, behaviours, skills, abilities, sounds and FX!";
                    Style: @CenteredBodyTextStyle;
                }

                Group { FlexWeight: 1; }
            }

            Group { Anchor: (Height: 10); }

            Group {
                LayoutMode: Middle;
                Anchor: (Height: 30);

                Group { FlexWeight: 1; }

                Group {
                    LayoutMode: Left;
                    Anchor: (Width: 484, Height: 30);

                    TextButton #HomeWebsiteButton {
                        Anchor: (Width: 156, Height: 30);
                        Text: "STARKYMODS";
                        Style: @TabButtonStyle;
                    }

                    Group { Anchor: (Width: 8); }

                    TextButton #HomeDiscordButton {
                        Anchor: (Width: 156, Height: 30);
                        Text: "DISCORD";
                        Style: @TabButtonStyle;
                    }

                    Group { Anchor: (Width: 8); }

                    TextButton #HomeCurseforgeButton {
                        Anchor: (Width: 156, Height: 30);
                        Text: "CURSEFORGE";
                        Style: @TabButtonStyle;
                    }
                }

                Group { FlexWeight: 1; }
            }

            Group { Anchor: (Height: 10); }

            Group {
                LayoutMode: Middle;
                Anchor: (Height: 40);

                Group { FlexWeight: 1; }

                Label {
                    Anchor: (Width: 620, Height: 40);
                    Text: "We do not have a wiki for this mod yet. For now, you can see how to use Cap's Shield at the mod description in CurseForge.";
                    Style: @CenteredBodyTextStyle;
                }

                Group { FlexWeight: 1; }
            }

            Group { Anchor: (Height: 12); }

            Group {
                LayoutMode: Middle;
                Anchor: (Height: 28);

                Group { FlexWeight: 1; }

                Label {
                    Anchor: (Width: 360, Height: 28);
                    Text: "MORE BY STARKYMODS";
                    Style: @HomeLargeTitleStyle;
                }

                Group { FlexWeight: 1; }
            }

            Group { Anchor: (Height: 10); }

            Group #HomeMoreRow1 {
                LayoutMode: Left;
                Anchor: (Height: 188);

                Group { FlexWeight: 1; }

                Group {
                    LayoutMode: Left;
                    Anchor: (Width: 714, Height: 188);

                    Button #HomeCard1 {
                        Anchor: (Width: 230, Height: 188, Right: 12);
                        LayoutMode: Top;
                        Style: @HomeLinkedCardButtonStyle;
                        Padding: (Full: 14);

                        Group {
                            LayoutMode: Middle;
                            Anchor: (Height: 114, Bottom: 12);
                            Group {
                                Anchor: (Width: 202, Height: 114);
                                Background: (TexturePath: "../Starky_Mjolnir_Wallpaper.png");
                            }
                        }
                        Group { FlexWeight: 1; }
                        Label { Text: "Starky's Mjolnir"; Anchor: (Height: 42); Style: @HomeCardTitleStyle; }
                    }

                    Group { Anchor: (Width: 12); }

                    Button #HomeCard2 {
                        Anchor: (Width: 230, Height: 188, Right: 12);
                        LayoutMode: Top;
                        Style: @HomeLinkedCardButtonStyle;
                        Padding: (Full: 14);

                        Group {
                            LayoutMode: Middle;
                            Anchor: (Height: 114, Bottom: 12);
                            Group {
                                Anchor: (Width: 202, Height: 114);
                                Background: (TexturePath: "../HyVoiceZoo_Wallpaper.png");
                            }
                        }
                        Group { FlexWeight: 1; }
                        Label { Text: "Hy Voice Zoo"; Anchor: (Height: 42); Style: @HomeCardTitleStyle; }
                    }

                    Group { Anchor: (Width: 12); }

                    Button #HomeCard3 {
                        Anchor: (Width: 230, Height: 188);
                        LayoutMode: Top;
                        Style: @HomeLinkedCardButtonStyle;
                        Padding: (Full: 14);

                        Group {
                            LayoutMode: Middle;
                            Anchor: (Height: 114, Bottom: 12);
                            Group {
                                Anchor: (Width: 202, Height: 114);
                                Background: (TexturePath: "../StasisRifle_Wallpaper.png");
                            }
                        }
                        Group { FlexWeight: 1; }
                        Label { Text: "Subnautica Stasis Rifle"; Anchor: (Height: 42); Style: @HomeCardTitleStyle; }
                    }
                }

                Group { FlexWeight: 1; }
            }

            Group { Anchor: (Height: 12); }

            Group #HomeMoreRow2 {
                LayoutMode: Left;
                Anchor: (Height: 188);

                Group { FlexWeight: 1; }

                Group {
                    LayoutMode: Left;
                    Anchor: (Width: 714, Height: 188);

                    Button #HomeCard4 {
                        Anchor: (Width: 230, Height: 188, Right: 12);
                        LayoutMode: Top;
                        Style: @HomeLinkedCardButtonStyle;
                        Padding: (Full: 14);

                        Group {
                            LayoutMode: Middle;
                            Anchor: (Height: 114, Bottom: 12);
                            Group {
                                Anchor: (Width: 202, Height: 114);
                                Background: (TexturePath: "../Starky_RayGun_Wallpaper.png");
                            }
                        }
                        Group { FlexWeight: 1; }
                        Label { Text: "Starky's RayGun"; Anchor: (Height: 42); Style: @HomeCardTitleStyle; }
                    }

                    Group { Anchor: (Width: 12); }

                    Button #HomeCard5 {
                        Anchor: (Width: 230, Height: 188);
                        LayoutMode: Top;
                        Style: @HomeLinkedCardButtonStyle;
                        Padding: (Full: 14);

                        Group {
                            LayoutMode: Middle;
                            Anchor: (Height: 114, Bottom: 12);
                            Group {
                                Anchor: (Width: 202, Height: 114);
                                Background: (TexturePath: "../Starky_ThunderGun_Wallpaper.png");
                            }
                        }
                        Group { FlexWeight: 1; }
                        Label { Text: "Starky's ThunderGun"; Anchor: (Height: 42); Style: @HomeCardTitleStyle; }
                    }

                    Group { Anchor: (Width: 12); }

                    Button #HomeCard6 {
                        Anchor: (Width: 230, Height: 188);
                        LayoutMode: Top;
                        Style: @HomeLinkedCardButtonStyle;
                        Padding: (Full: 14);

                        Group {
                            LayoutMode: Middle;
                            Anchor: (Height: 114, Bottom: 12);
                            Group {
                                Anchor: (Width: 202, Height: 114);
                                Background: (TexturePath: "../FartGun_Wallpaper.png");
                            }
                        }
                        Group { FlexWeight: 1; }
                        Label { Text: "The Fart Gun"; Anchor: (Height: 42); Style: @HomeCardTitleStyle; }
                    }
                }

                Group { FlexWeight: 1; }
            }

            Group { Anchor: (Height: 12); }

            Group #HomeMoreRow3 {
                LayoutMode: Left;
                Anchor: (Height: 188);

                Group { FlexWeight: 1; }

                Group {
                    LayoutMode: Left;
                    Anchor: (Width: 714, Height: 188);

                    Button #HomeCard7 {
                        Anchor: (Width: 230, Height: 188, Right: 12);
                        LayoutMode: Top;
                        Style: @HomeLinkedCardButtonStyle;
                        Padding: (Full: 14);

                        Group {
                            LayoutMode: Middle;
                            Anchor: (Height: 114, Bottom: 12);
                            Group {
                                Anchor: (Width: 202, Height: 114);
                                Background: (TexturePath: "../CustomSkinKeeper_Wallpaper.png");
                            }
                        }
                        Group { FlexWeight: 1; }
                        Label { Text: "Custom Skin Keeper"; Anchor: (Height: 42); Style: @HomeCardTitleStyle; }
                    }

                    Group { Anchor: (Width: 12); }

                    Button #HomeCard8 {
                        Anchor: (Width: 230, Height: 188);
                        LayoutMode: Top;
                        Style: @HomeLinkedCardButtonStyle;
                        Padding: (Full: 14);

                        Group {
                            LayoutMode: Middle;
                            Anchor: (Height: 114, Bottom: 12);
                            Group {
                                Anchor: (Width: 202, Height: 114);
                                Background: (TexturePath: "../BlockingItems_Wallpaper.png");
                            }
                        }
                        Group { FlexWeight: 1; }
                        Label { Text: "Blocking Items"; Anchor: (Height: 42); Style: @HomeCardTitleStyle; }
                    }

                    Group { Anchor: (Width: 12); }

                    Group {
                        Anchor: (Width: 230, Height: 188);
                    }
                }

                Group { FlexWeight: 1; }
            }

            Group { Anchor: (Height: 18); }
        }
    }

    Group #MainTab {
        LayoutMode: Top;
        FlexWeight: 1;
        Visible: true;
        Padding: (Horizontal: 24);

        Label {
            Text: "CAP'S SHIELD CONFIG";
            Anchor: (Height: 20);
            Style: @SectionLabelStyle;
        }
        Group { Anchor: (Height: 4); }

        Label {
            Text: "Configured abilities and general behavior for CAP'S SHIELD.";
            Anchor: (Height: 26);
            Style: @BodyTextStyle;
        }

        Group { Anchor: (Height: 6); }

        Group #MainScroll {
            FlexWeight: 1;
            LayoutMode: TopScrolling;
            ScrollbarStyle: $Common.@DefaultScrollbarStyle;

            Group { LayoutMode: Left; Anchor: (Height: 24);
                TextButton #ResetMainButton { Anchor: (Width: 92, Height: 24); Text: "Reset"; Style: @RemoveButtonStyle; }
            }
            Group { Anchor: (Height: 8); }

            Label { Text: "GENERAL"; Anchor: (Height: 20); Style: @SectionLabelStyle; }
            Group { Anchor: (Height: 6); }

            Group { LayoutMode: Left; Anchor: (Height: 24);
                CheckBox #AllowCraftingToggle { Anchor: (Width: 18, Height: 18); Background: #371c1c; Padding: (Full: 2); Style: $Common.@DefaultCheckBoxStyle; }
                Group { Anchor: (Width: 8); }
                Label { FlexWeight: 1; Text: "Allow Shield Craft"; Style: @RowLabelStyle; }
            }
            Group { LayoutMode: Left; Anchor: (Height: 24);
                CheckBox #KeepSignatureEnergyToggle { Anchor: (Width: 18, Height: 18); Background: #371c1c; Padding: (Full: 2); Style: $Common.@DefaultCheckBoxStyle; }
                Group { Anchor: (Width: 8); }
                Label { FlexWeight: 1; Text: "Shield keeps Signature Energy when swapped"; Style: @RowLabelStyle; }
            }
            Group { LayoutMode: Left; Anchor: (Height: 24);
                CheckBox #VisualShieldInPlayersBackToggle { Anchor: (Width: 18, Height: 18); Background: #371c1c; Padding: (Full: 2); Style: $Common.@DefaultCheckBoxStyle; }
                Group { Anchor: (Width: 8); }
                Label { FlexWeight: 1; Text: "Visual Shield in player back"; Style: @RowLabelStyle; }
            }
            Group { LayoutMode: Left; Anchor: (Height: 24);
                CheckBox #FallResistanceWhenBlockingToggle { Anchor: (Width: 18, Height: 18); Background: #371c1c; Padding: (Full: 2); Style: $Common.@DefaultCheckBoxStyle; }
                Group { Anchor: (Width: 8); }
                Label { FlexWeight: 1; Text: "Fall Resistance when blocking"; Style: @RowLabelStyle; }
            }
            Group { LayoutMode: Left; Anchor: (Height: 24);
                CheckBox #DamageFromBackResistanceToggle { Anchor: (Width: 18, Height: 18); Background: #371c1c; Padding: (Full: 2); Style: $Common.@DefaultCheckBoxStyle; }
                Group { Anchor: (Width: 8); }
                Label { FlexWeight: 1; Text: "Damage from the Back Resistance"; Style: @RowLabelStyle; }
            }

            Group { Anchor: (Height: 12); }
            Label { Text: "ATTACKS & ABILITIES"; Anchor: (Height: 20); Style: @SectionLabelStyle; }
            Group { Anchor: (Height: 4); }
            Label #MainConfigNote { Text: ""; Anchor: (Height: 10); Style: @NoteTextStyle; }
            Group { LayoutMode: Left; Anchor: (Height: 24);
                CheckBox #DoubleJumpToggle { Anchor: (Width: 18, Height: 18); Background: #371c1c; Padding: (Full: 2); Style: $Common.@DefaultCheckBoxStyle; }
                Group { Anchor: (Width: 8); }
                Label { FlexWeight: 1; Text: "Double Jump (disabling this includes the FallStar Attack)"; Style: @RowLabelStyle; }
            }
            Group { LayoutMode: Left; Anchor: (Height: 24);
                CheckBox #FallStarAttackToggle { Anchor: (Width: 18, Height: 18); Background: #371c1c; Padding: (Full: 2); Style: $Common.@DefaultCheckBoxStyle; }
                Group { Anchor: (Width: 8); }
                Label { FlexWeight: 1; Text: "FallStar Attack"; Style: @RowLabelStyle; }
            }
            Group { LayoutMode: Left; Anchor: (Height: 24);
                CheckBox #GuardBashToggle { Anchor: (Width: 18, Height: 18); Background: #371c1c; Padding: (Full: 2); Style: $Common.@DefaultCheckBoxStyle; }
                Group { Anchor: (Width: 8); }
                Label { FlexWeight: 1; Text: "Guard Bash"; Style: @RowLabelStyle; }
            }
            Group { LayoutMode: Left; Anchor: (Height: 24);
                CheckBox #GuardBashPushLaunchToggle { Anchor: (Width: 18, Height: 18); Background: #371c1c; Padding: (Full: 2); Style: $Common.@DefaultCheckBoxStyle; }
                Group { Anchor: (Width: 8); }
                Label { FlexWeight: 1; Text: "Guard Bash Push Launch"; Style: @RowLabelStyle; }
            }
            Group { LayoutMode: Left; Anchor: (Height: 24);
                CheckBox #SprintAttackToggle { Anchor: (Width: 18, Height: 18); Background: #371c1c; Padding: (Full: 2); Style: $Common.@DefaultCheckBoxStyle; }
                Group { Anchor: (Width: 8); }
                Label { FlexWeight: 1; Text: "Sprint Attack"; Style: @RowLabelStyle; }
            }
            Group { LayoutMode: Left; Anchor: (Height: 24);
                CheckBox #KickPushAttackToggle { Anchor: (Width: 18, Height: 18); Background: #371c1c; Padding: (Full: 2); Style: $Common.@DefaultCheckBoxStyle; }
                Group { Anchor: (Width: 8); }
                Label { FlexWeight: 1; Text: "Kick Push Attack"; Style: @RowLabelStyle; }
            }
            Group { LayoutMode: Left; Anchor: (Height: 24);
                CheckBox #ThrowToggle { Anchor: (Width: 18, Height: 18); Background: #371c1c; Padding: (Full: 2); Style: $Common.@DefaultCheckBoxStyle; }
                Group { Anchor: (Width: 8); }
                Label { FlexWeight: 1; Text: "Throw"; Style: @RowLabelStyle; }
            }
            Group { LayoutMode: Left; Anchor: (Height: 24);
                CheckBox #ThrowLeftHandToggle { Anchor: (Width: 18, Height: 18); Background: #371c1c; Padding: (Full: 2); Style: $Common.@DefaultCheckBoxStyle; }
                Group { Anchor: (Width: 8); }
                Label { FlexWeight: 1; Text: "Throw Left Hand"; Style: @RowLabelStyle; }
            }
            Group { LayoutMode: Left; Anchor: (Height: 24);
                CheckBox #FuriousOnslaughtToggle { Anchor: (Width: 18, Height: 18); Background: #371c1c; Padding: (Full: 2); Style: $Common.@DefaultCheckBoxStyle; }
                Group { Anchor: (Width: 8); }
                Label { FlexWeight: 1; Text: "Furious Onslaught"; Style: @RowLabelStyle; }
            }
            Group { LayoutMode: Left; Anchor: (Height: 24);
                CheckBox #GuardBashShockwaveMjolnirToggle { Anchor: (Width: 18, Height: 18); Background: #371c1c; Padding: (Full: 2); Style: $Common.@DefaultCheckBoxStyle; }
                Group { Anchor: (Width: 8); }
                Label { FlexWeight: 1; Text: "Guard Bash Shockwave with Mjolnir"; Style: @RowLabelStyle; }
            }
        }
        Group { Anchor: (Height: 10); }

        Group {
            LayoutMode: Left;
            Anchor: (Height: 32);

            Group { FlexWeight: 1; }
            TextButton #SaveMainButton {
                Anchor: (Width: 140, Height: 32);
                Text: "Apply";
                Style: @ApplyButtonStyle;
            }
        }
    }

    Group #CraftTab {
        LayoutMode: Top;
        FlexWeight: 1;
        Visible: false;
        Padding: (Horizontal: 24);

