    Group #CompatibilityTab {
        LayoutMode: Top;
        FlexWeight: 1;
        Visible: false;
        Padding: (Horizontal: 24);

        Label { Text: "COMPATIBILITY"; Anchor: (Height: 20); Style: @SectionLabelStyle; }
        Group { Anchor: (Height: 4); }
        Label { Text: "Partners and recommended mods that fit really well with CAP'S SHIELD."; Anchor: (Height: 26); Style: @BodyTextStyle; }
        Label { Text: "These are Optional Integrations — All Auto-Detected."; Anchor: (Height: 22); Style: @NoteTextStyle; }
        Group { Anchor: (Height: 6); }

        Group #CompatibilityScroll {
            FlexWeight: 1;
            LayoutMode: TopScrolling;
            ScrollbarStyle: $Common.@DefaultScrollbarStyle;

            Group #CompatibilityPartnersSection {
                LayoutMode: Top;

                Group {
                    LayoutMode: Left;
                    Anchor: (Width: 767, Height: 132);

                    Button #CompatibilityShieldCard {
                        Anchor: (Width: 700, Height: 132, Right: 8);
                        Style: @CompatibilityLinkedCardButtonStyle;
                        Padding: (Full: 12);

                        Group {
                            LayoutMode: Left;
                            Anchor: (Width: 676, Height: 108);

                            Group {
                                Anchor: (Width: 88, Height: 88, Right: 14);
                                Background: (TexturePath: "../Starky_Mjolnir_Icon.png");
                            }

                            Group {
                                LayoutMode: Top;
                                Anchor: (Width: 574, Height: 108);

                                Label {
                                    Text: "STARKY'S MJOLNIR - SPECIAL COMPATIBILITY";
                                    Anchor: (Height: 22, Bottom: 6);
                                    Style: (FontSize: 17, TextColor: #ffffff, RenderBold: true, Wrap: true, VerticalAlignment: Center);
                                }

                                Label {
                                    Text: "Adds the Thor's Hammer MJOLNIR from Marvel with lots of attacks, skills, etc. If installed and active, the player can execute special attacks, skills, throws and more by equipping Mjolnir(right hand) and the Shield(left hand).";
                                    Anchor: (Height: 80);
                                    Style: (FontSize: 14, TextColor: #e4bfbf, Wrap: true);
                                }
                            }
                        }
                    }

                    TextButton #CompatibilityShieldMenuButton {
                        Anchor: (Width: 59, Height: 22);
                        Text: "MENU";
                        Style: @MenuMiniButtonStyle;
                    }
                }

                Group { Anchor: (Height: 16); }

                Group {
                    LayoutMode: Top;
                    Background: #1f0b0b(0.88);
                    Padding: (Full: 18);

                    Label {
                        Text: "MOD PARTNERS";
                        Anchor: (Height: 24);
                        Style: (FontSize: 18, TextColor: #ffffff, RenderBold: true);
                    }

                    Group { Anchor: (Height: 6); }

                    Label {
                        Text: "External mod partners.";
                        Style: (FontSize: 13, TextColor: #e4bfbf, Wrap: true);
                    }
                }

                Group { Anchor: (Height: 18); }

                Group #CompatibilityPartnersRow1 {
                    LayoutMode: Left;
                    Anchor: (Height: 360);

                    Group { FlexWeight: 1; }

                    Group {
                        LayoutMode: Left;
                        Anchor: (Width: 656, Height: 360);

                        Group {
                            LayoutMode: Top;
